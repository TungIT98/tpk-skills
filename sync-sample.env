# TPK Skills Environment Variables
# Copy file này thành .env và điền thông tin thật

# GitHub (cho sync)
GITHUB_TOKEN=

# ClawHub (cho publish)
CLAWHUB_TOKEN=

# Paperclip API (cho paperclip-sync skill)
# Thường là local: http://127.0.0.1:3100
PAPERCLIP_API_URL=http://127.0.0.1:3100

# Các API keys khác nếu cần
# LINEAR_API_KEY=
# NOTION_TOKEN=
# SENTRY_TOKEN=
